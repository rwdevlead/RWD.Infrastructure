# RWD.Infrastructure Environment Variables
# Copy this file to .env and fill in your actual values
# The .env file is gitignored to prevent committing secrets

# ======================================================================
# Cloudflare DNS API Configuration (Required for Traefik SSL Certificates)
# ======================================================================
# Get your API token from: https://dash.cloudflare.com/profile/api-tokens
# Requires at least "Zone.DNS:Edit" permissions
# Required by: iac/ansible/roles/apps/traefik
CF_DNS_API_TOKEN="your_cloudflare_api_token_here"

# ======================================================================
# Optional: Other Infrastructure Credentials
# ======================================================================
# Proxmox API credentials (when needed)
# PROXMOX_USERNAME="root@pam"
# PROXMOX_TOKEN="your_proxmox_api_token"

# GitHub credentials (when needed)
# GITHUB_TOKEN="your_github_personal_access_token"

# ======================================================================
# Local Development Overrides
# ======================================================================
# Uncomment and modify to override Makefile defaults for local testing
# ENV=development
# TARGET=proxmox
