# ==========================================================
# Terraform
# ==========================================================
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraform.tfstate.lock.info
.terraformrc
terraform.rc
tfplan
*.tfplan
plan.out
*.plan
**/*.terraform
*.tfstate.backup
*.tfvars
*.tfplan
*.tfout
*.tflock
*.terraform.lock.*

# ==========================================================
# Packer
# ==========================================================
packer_cache/
*.pkrvars.hcl
*.pkrvars.json
.packer.d/plugins/
builds/
output-*/
*.log

# ==========================================================
# Ansible
# ==========================================================
# Ignore Ansible-generated files and cache, but track role/collection definitions
.vault_pass
**/*.retry
.ansible/fact-cache/
# Note: ansible.cfg, roles/, collections/, and inventories/ are tracked in git
# These contain the infrastructure-as-code definitions and should be committed

# ==========================================================
# Environment
# ==========================================================
.env
.env.*
!.env.example
env/
!env/**/.example
!env/*.example

# ==========================================================
# Editor / IDE
# ==========================================================
.vscode/
*.code-workspace
.vscode-test/
**/.DS_Store
**/Thumbs.db
.bfg-report/

# ==========================================================
# AI AGENT / ASSISTANT GENERATED FILES
# Ignore metadata, plans, logs, and outputs created by AI tools
# (GitHub Copilot, ChatGPT, Cursor, Codeium, Claude, etc.)
# ==========================================================

# Generic AI output and temp dirs
/chatgpt/
/openai/
/ai*/           # covers /ai_output/, /ai_generated/, /ai_cache/, etc.
/tmp-ai/
/auto_gen/
/generated_*/
/drafts_ai/
/sandbox_ai/
/llm_*/         # covers llm_cache, llm_runs, etc.
/model_output/
/agent_*/       # covers /agent_runs/, /agents/, etc.

# GitHub Copilot (Workspace / Agent)
# NOTE: DO NOT ignore copilot-instructions.md or .instructions.md - these are configuration files
# that should be tracked in git. Only ignore runtime caches and artifacts.
.copilot/       # Cache directory only, not instructions
.copilot-chat/  # Chat history cache

# Cursor IDE
/.cursor*/       # covers .cursor/, .cursor-history/, .cursordb/, cursor-cache/

# Codeium
/.codeium*/      # covers .codeium/, .codeium-cache/, etc.

# Replit AI
/.replit*/       # covers .replit-ai/, .replit-history/

# Tabnine
/tabnine*
*.tabnine.log

# Amazon CodeWhisperer
/.codewhisperer*/

# JetBrains AI Assistant
/.idea/ai*/      # covers ai/, aiAssistant/, __ai__

# Visual Studio / VS Code IntelliCode
/.vs/intellicode/
/.vscode/.intellicode/

# Claude / Anthropic
/claude-*/       # covers claude-cache/, claude-output/, claude-sessions/

# AI notebook / experiment frameworks
*.ipynb_checkpoints
/notebooks/
/experiments/
/runs/
/wandb/
/mlruns/
/logs/

# Obsidian or VSCode AI plugin data
/.vscode/ai/
/.obsidian/plugins/*ai*/

# BFG Repo-Cleaner 
bfg-report/
..bfg-report/
