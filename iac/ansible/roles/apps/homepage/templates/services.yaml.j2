---
# For configuration options and examples, please see:
# https://gethomepage.dev/configs/services

- Network:
{% for pihole in pihole_instances %}
    - {{ pihole.name }}:
        icon: pi-hole.svg
        href: {{ pihole.url }}
        description: Pi-hole DNS on Docker
        server: {{ pihole.server }}
        container: {{ pihole.container }}
        siteMonitor: {{ pihole.url }}
        widget:
            type: pihole
            url: {{ pihole.url }}
            version: 6
            key: {{ lookup('ansible.builtin.env', pihole.env_user_pwd) }}
{% endfor %}
    - traefik:
        icon: traefik.svg
        href: {{ homepage_var_proxy_url }}
        server: dev-docker-01 # The docker server that was configured
        container: traefik-d01 # The name of the container you'd like to connect
        siteMonitor: {{ homepage_var_proxy_url }}
        description: Reverse Proxy
        widget:
            type: traefik
            url: {{ homepage_var_proxy_url }}
            # username: admin # optional
            # password: {{ homepage_var_proxy_password }}

- Local Servers:
{% for pve in proxmox_instances %}
    - {{ pve.name }}:
        icon: proxmox.svg
        href: {{ pve.url }}
        description: Proxmox Virtual Environment
        siteMonitor: {{ pve.url }}
        widget:
            type: proxmox
            url: {{ pve.url }}
            # Using your existing global user/key for all nodes
            username: "{{ lookup('ansible.builtin.env', pve.env_user_key) }}"
            password: "{{ lookup('ansible.builtin.env', pve.env_token_key) }}"
{% endfor %}
    - TrueNAS:
        statusStyle: "basic"
        icon: truenas.svg
        href: {{ homepage_var_truenas_url }}
        description: backups on NAS
        siteMonitor: {{ homepage_var_truenas_url }}
        widget:
            type: truenas
            url: {{ homepage_var_truenas_url }}
            # username: user # not required if using api key
            # password: pass # not required if using api key
            key: {{ homepage_var_truenas_key }} # not required if using username / password
            enablePools: true # optional, defaults to false
            nasType: scale # defaults to scale, must be set to 'core' if using enablePools with TrueNAS Core
- Containers:
    - portainer-dev:
        statusStyle: "basic"
        icon: portainer.svg
        href: {{ homepage_var_portainer_dev_url }}
        #href: https://192.168.50.14:9443
        description: Container Management 
        siteMonitor: {{ homepage_var_portainer_dev_url }}
        #siteMonitor: https://192.168.50.14:9443
        widget:
            type: portainer
            #url: https://192.168.50.14:9443
            url: {{ homepage_var_portainer_dev_url }}
            env: 3
            key: {{ homepage_var_portainer_dev_key }}
            #key: ptr_FdP+k0xwP+qyvRHknVfcOr4+P33j35FZ9I97UqXuqSQ=

- IoT:
    # - Watchtower:
        # icon: watchtower.svg
        # href: https://portainer.yourdomain.com # Link it back to your management view
        # description: Automated Container Updates
        # server: dev-docker-01
        # container: watchtower # Matches the container_name value
    - Nebula Sync:
        icon: mdi-sync # Uses standard Material Design Icons
        description: Pi-hole Database Synchronizer
        server: prod-docker-01
        container: nebula-sync
        # Optional: Tells Homepage to verify the container background health state
        siteMonitor: http://192.168.50.14:8888/api/auth 
    # - Mailrise Gateway:
        # icon: mdi-email-alert
        # href: mailto:alert@yourdomain.com
        # description: SMTP Notification Routing Engine
        # siteMonitor: http://192.168.50.12:8025 # Verifies the port responds to raw socket hooks
    - Home Assistant:
        icon: home-assistant.svg
        href: "{{ lookup('ansible.builtin.env', 'HOMEASSISTANT_URL') }}"
        description: Home Automation System
        widget:
          type: homeassistant
          url: "{{ lookup('ansible.builtin.env', 'HOMEASSISTANT_URL') }}"
          key: "{{ lookup('ansible.builtin.env', 'HOMEASSISTANT_TOKEN') }}"
          # Standard quick summaries:
          fields: ["lights_on", "switches_on", "people_home"]
          # Custom entity tracks (Optional: remove or swap to your actual sensors):
          # custom:
          #   - state: sensor.total_power
          #     label: Total Power

