services:
  mailrise:
    image: {{ mailrise_image }}:{{ mailrise_tag }}
    container_name: {{ mailrise_container_name }}
    restart: unless-stopped
    ports:
      - "{{ mailrise_smtp_port }}:8025"
      - "8081:8080"    
    volumes:
      - "{{ mailrise_data_dir }}/config/mailrise.conf:/etc/mailrise.conf:ro"
    command: ["/etc/mailrise.conf"]
    environment:
      - MAILRISE_GUI_ENABLED=true  # Note: It's GUI, not WEB
      - MAILRISE_GUI_PORT=8080
      - PYTHONUNBUFFERED=1
    networks:
      - {{ shared_docker_network }}
    labels:
      - "traefik.enable=true"
      - "traefik.tcp.routers.mailrise.rule=HostSNI(`*`)"
      - "traefik.tcp.routers.mailrise.entrypoints=smtp"
      - "traefik.tcp.routers.mailrise.service=mailrise"
      - "traefik.tcp.services.mailrise.loadbalancer.server.port=8025"

networks:
  {{ shared_docker_network }}:
    external: true