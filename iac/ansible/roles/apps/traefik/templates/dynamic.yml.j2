http:
  routers:
    dashboard:
      entryPoints:
        - "websecure"
      rule: "Host(`{{ traefik_instance.domain }}`)"
      middlewares:
        - default-headers
      tls:
        certResolver: "{{ traefik_acme_resolver }}"
        domains:
          - main: "{{ traefik_acme_domain_main }}"
            sans:
{% for sans in traefik_acme_domain_sans.split(',') %}
              - "{{ sans | trim }}"
{% endfor %}
      service: api@internal
    dashboard-http:
      entryPoints:
        - "web"
      rule: "Host(`{{ traefik_instance.domain }}`)"
      middlewares:
        - https-redirectscheme
      service: api@internal
{% for pve in proxmox_instances %}
    {{ pve.name }}:
      entryPoints:
        - "web"
        - "websecure"
      rule: "Host(`{{ pve.domain }}`)"
      middlewares:
        - https-redirectscheme
        - default-headers
      tls:
        certResolver: "{{ traefik_acme_resolver }}"
        domains:
          - main: "{{ traefik_acme_domain_main }}"
            sans:
{% for sans in traefik_acme_domain_sans.split(',') %}
              - "{{ sans | trim }}"
{% endfor %}
      service: {{ pve.name }}
{% endfor %}
    pihole-prod:      
      entryPoints:
        - "websecure"
      rule: "Host(`pihole-p01.local.rwdevs.com`)"
      middlewares:
        - default-headers
        - pihole-redirect      
      tls:
        certResolver: "cloudflare"
      service: "pihole-prod-service"
    ha-router:
      entryPoints:
        - "websecure"
      rule: "Host(`ha.local.rwdevs.com`)"
      middlewares:
        - default-headers
      tls:
        certResolver: "cloudflare"
      service: "ha-service"
  services:
    pihole-prod-service:
      loadBalancer:
        servers:
          - url: "http://192.168.50.14:8888"
    ha-service:
      loadBalancer:
        servers:
          - url: "http://192.168.50.15:8123"
{% for pve in proxmox_instances %}
    {{ pve.name }}:
      loadBalancer:
        servers:
          - url: "{{ pve.url }}"
        passHostHeader: true
        serversTransport: proxmox-transport
{% endfor %}  
  serversTransports:
    proxmox-transport:
      insecureSkipVerify: true
  middlewares:
    https-redirectscheme:
      redirectScheme:
        scheme: https
        permanent: true
    pihole-redirect:
      redirectRegex:
        regex: "^https://pihole-p01.local.rwdevs.com/$$"
        replacement: "https://pihole-p01.local.rwdevs.com/admin/"
    default-headers:
      headers:
        frameDeny: true
        browserXssFilter: true
        contentTypeNosniff: true
        forceSTSHeader: true
        stsIncludeSubdomains: true
        stsPreload: true
        stsSeconds: {{ traefik_hsts_max_age }}
        customFrameOptionsValue: SAMEORIGIN
        customRequestHeaders:
          X-Forwarded-Proto: https
    default-whitelist:
      ipAllowList:
        sourceRange:
{% for ip in traefik_ip_whitelist %}
          - "{{ ip }}"
{% endfor %}   
    # Secured middleware for services - includes IP whitelist
    secured:
      chain:
        middlewares:
          - default-whitelist
          - default-headers
